# Copy this file to .env and fill in your credentials.
# .env is git-ignored and must NEVER be committed.

# -------------------------------------------------------------------
# Copernicus Data Space Ecosystem (Sentinel-2 downloads)
# Register at: https://dataspace.copernicus.eu/
# -------------------------------------------------------------------
CDSE_EMAIL=your_email@example.com
CDSE_PASSWORD=your_password_here

# -------------------------------------------------------------------
# Google Earth Engine
# Project ID from: https://console.cloud.google.com/
# Usually looks like "ee-yourname" or "my-project-12345"
# -------------------------------------------------------------------
GEE_PROJECT_ID=your-gee-project-id
